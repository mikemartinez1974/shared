      "data": {
        "nodeDefs": [
          {
            "key": "lifecycle-probe",
            "ref": "/tlz/project1/complaint.node-class.node",
            "source": "local",
            "version": ">=0.1.0",
            "legend": {
              "visible": true
            },
            "defaults": {
              "label": "Lifecycle Probe",
              "size": {
                "width": 360,
                "height": 220
              },
              "data": {
                "complaint": "Lifecycle probe initialized.",
                "status": "open",
                "severity": "minor",
                "reportedBy": "system"
              }
            },
            "overrides": {
              "allowLabel": true,
              "allowSize": true,
              "allowColor": true,
              "allowPorts": true,
              "allowData": true,
              "dataMode": "merge-deep"
            },
            "validation": {
              "requiredDataKeys": [
                "data.complaint"
              ],
              "rules": [
                {
                  "id": "complaint-required",
                  "kind": "required",
                  "path": "data.complaint",
                  "message": "complaint text required",
                  "severity": "error"
                }
              ],
              "onError": "warn"
            },
            "lifecycle": {
              "hooks": {
                "onCreate": {
                  "kind": "script",
                  "ref": "const logNodeId = 'lifecycle-log';\nconst now = new Date().toISOString();\nconst nodes = await api.getNodes();\nconst logNode = nodes.find((n) => n && n.id === logNodeId);\nif (!logNode) {\n  await api.log('warn', '[LifecycleSmoke] Missing lifecycle log node');\n  return { hook: 'onCreate', logged: false };\n}\nconst prev = String(logNode?.data?.markdown || '# Lifecycle Hook Log\\n\\n');\nconst line = '- ' + now + ' :: onCreate fired';\nawait api.updateNode(logNodeId, { data: { markdown: prev + '\\n' + line } });\nreturn { hook: 'onCreate', logged: true, at: now };",
                  "timeoutMs": 2000
                },
                "onLoad": {
                  "kind": "script",
                  "ref": "const logNodeId = 'lifecycle-log';\nconst now = new Date().toISOString();\nconst nodes = await api.getNodes();\nconst logNode = nodes.find((n) => n && n.id === logNodeId);\nif (!logNode) {\n  await api.log('warn', '[LifecycleSmoke] Missing lifecycle log node');\n  return { hook: 'onLoad', logged: false };\n}\nconst prev = String(logNode?.data?.markdown || '# Lifecycle Hook Log\\n\\n');\nconst line = '- ' + now + ' :: onLoad fired';\nawait api.updateNode(logNodeId, { data: { markdown: prev + '\\n' + line } });\nreturn { hook: 'onLoad', logged: true, at: now };",
                  "timeoutMs": 2000
                },
                "onBeforeUpdate": {
                  "kind": "script",
                  "ref": "const logNodeId = 'lifecycle-log';\nconst now = new Date().toISOString();\nconst nodes = await api.getNodes();\nconst logNode = nodes.find((n) => n && n.id === logNodeId);\nif (!logNode) {\n  await api.log('warn', '[LifecycleSmoke] Missing lifecycle log node');\n  return { hook: 'onBeforeUpdate', logged: false };\n}\nconst prev = String(logNode?.data?.markdown || '# Lifecycle Hook Log\\n\\n');\nconst line = '- ' + now + ' :: onBeforeUpdate fired';\nawait api.updateNode(logNodeId, { data: { markdown: prev + '\\n' + line } });\nreturn { hook: 'onBeforeUpdate', logged: true, at: now };",
                  "timeoutMs": 2000
                },
                "onAfterUpdate": {
                  "kind": "script",
                  "ref": "const logNodeId = 'lifecycle-log';\nconst now = new Date().toISOString();\nconst nodes = await api.getNodes();\nconst logNode = nodes.find((n) => n && n.id === logNodeId);\nif (!logNode) {\n  await api.log('warn', '[LifecycleSmoke] Missing lifecycle log node');\n  return { hook: 'onAfterUpdate', logged: false };\n}\nconst prev = String(logNode?.data?.markdown || '# Lifecycle Hook Log\\n\\n');\nconst line = '- ' + now + ' :: onAfterUpdate fired';\nawait api.updateNode(logNodeId, { data: { markdown: prev + '\\n' + line } });\nreturn { hook: 'onAfterUpdate', logged: true, at: now };",
                  "timeoutMs": 2000
                },
                "onDelete": {
                  "kind": "script",
                  "ref": "const logNodeId = 'lifecycle-log';\nconst now = new Date().toISOString();\nconst nodes = await api.getNodes();\nconst logNode = nodes.find((n) => n && n.id === logNodeId);\nif (!logNode) {\n  await api.log('warn', '[LifecycleSmoke] Missing lifecycle log node');\n  return { hook: 'onDelete', logged: false };\n}\nconst prev = String(logNode?.data?.markdown || '# Lifecycle Hook Log\\n\\n');\nconst line = '- ' + now + ' :: onDelete fired';\nawait api.updateNode(logNodeId, { data: { markdown: prev + '\\n' + line } });\nreturn { hook: 'onDelete', logged: true, at: now };",
                  "timeoutMs": 2000
                }
              }
            }
          }
        ],
